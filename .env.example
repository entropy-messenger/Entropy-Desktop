# 🌐 Entropy Relay Configuration

# The URL of the Entropy Relay server for personal use
# When building for production, set this to your public relay address.
# Ensure it includes the protocol (http/https). 
# The application will automatically convert it to ws/wss for messaging.

VITE_RELAY_URL=http://localhost:8080

# (Optional) Hardened VDF Modulus if different from default
# ENTROPY_VDF_MODULUS=...
