{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Entropy",
    "version": "0.0.6",
    "identifier": "com.entropy.messenger",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://localhost:5173",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Entropy",
                "width": 1200,
                "height": 800,
                "decorations": false,
                "transparent": true
            }
        ],
        "security": {
            "csp": "default-src 'self' tauri: asset: blob:; connect-src 'self' tauri: ipc: ws: wss:; img-src 'self' tauri: asset: blob: data:; font-src 'self' tauri: data:; media-src 'self' blob:; script-src 'self' tauri:; style-src 'self' 'unsafe-inline' tauri:;",
            "capabilities": [
                "main"
            ]
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "createUpdaterArtifacts": true,
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.png",
            "icons/icon.ico",
            "icons/icon.icns"
        ]
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://www.entropymessenger.com/update.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4RkE4OEU1QUY0MEEzNUQKUldSZG8wQ3Y1WWo2R0FHRnBndTU0WTN4dE1pSzJJcmRKMmpiR1VQTlpMajltWVBNUHVpcE5BdGIK"
        }
    }
}